generator client {
  provider        = "prisma-client-js"
}

datasource db {
  provider   = "sqlite"
}

// =======================
// الجداول (Models)
// =======================

model User {
  id                   String         @id @default(cuid())
  name                 String
  email                String         @unique
  password             String
  phone                String?
  role                 String         @default("customer") // UserRole enum
  address              String?
  isActive             Boolean        @default(true)
  monthlyHourlyRate    Float          @default(0)

  // العلاقات (Relations)
  attendances             Attendance[]
  expenses                Expense[]
  pharmacistOrders        Order[]        @relation("PharmacistOrders")
  customerOrders          Order[]        @relation("CustomerOrders")
  customerPrescriptions   Prescription[] @relation("CustomerPrescriptions")
  pharmacistPrescriptions Prescription[] @relation("PharmacistPrescriptions")
  purchases               Purchase[]
  returns                 Return[]
  shifts                  Shift[]

  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt

  @@index([email])
}

model Attendance {
  id          String           @id @default(cuid())
  employeeId  String
  employee    User             @relation(fields: [employeeId], references: [id])
  date        DateTime
  checkIn     DateTime
  checkOut    DateTime?
  totalHours  Float            @default(0)
  status      String           @default("present") // AttendanceStatus enum
  notes       String?

  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@unique([employeeId, date])
  @@index([date])
}

model Category {
  id          String    @id @default(cuid())
  name        String    @unique
  description String?
  image       String?
  isActive    Boolean   @default(true)
  
  products    Product[]

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Product {
  id                   String           @id @default(cuid())
  name                 String
  scientificName       String?
  barcode              String           @unique
  description          String?
  image                String?
  
  categoryId           String?
  category             Category?        @relation(fields: [categoryId], references: [id])
  
  purchasingPrice      Float
  sellingPrice         Float
  stockQuantity        Int              @default(0)
  minStockAlert        Int              @default(10)
  expiryDate           DateTime
  requiresPrescription Boolean          @default(false)
  isAvailableOnline    Boolean          @default(false)
  unit                 String           @default("قطعة")
  
  supplierId           String?
  supplier             Supplier?        @relation(fields: [supplierId], references: [id])

  orderItems           OrderItem[]
  purchaseItems        PurchaseItem[]
  returnItems          ReturnItem[]

  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt

  @@index([barcode])
  @@index([sellingPrice])
  @@index([categoryId])
  @@index([expiryDate])
}

model Supplier {
  id        String     @id @default(cuid())
  name      String
  company   String
  phone     String
  dues      Float      @default(0)
  
  products  Product[]
  purchases Purchase[]

  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model Expense {
  id           String          @id @default(cuid())
  description  String
  amount       Float
  category     String          @default("other") // ExpenseCategory enum
  date         DateTime        @default(now())
  
  pharmacistId String
  pharmacist   User            @relation(fields: [pharmacistId], references: [id])

  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  @@index([date])
  @@index([pharmacistId, date])
}

model Shift {
  id           String      @id @default(cuid())
  pharmacistId String
  pharmacist   User        @relation(fields: [pharmacistId], references: [id])
  startTime    DateTime    @default(now())
  endTime      DateTime?
  startingCash Float       @default(0)
  endingCash   Float?
  expectedCash Float       @default(0)
  totalSales   Float       @default(0)
  totalOrders  Int         @default(0)
  totalReturns Float       @default(0)
  status       String      @default("open") // ShiftStatus enum
  notes        String?
  
  orders       Order[]

  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  @@index([pharmacistId, status])
  @@index([startTime])
}

model Order {
  id               String        @id @default(cuid())
  orderNumber      String?       @unique
  
  pharmacistId     String?
  pharmacist       User?         @relation("PharmacistOrders", fields: [pharmacistId], references: [id])
  
  customerId       String?
  customer         User?         @relation("CustomerOrders", fields: [customerId], references: [id])
  
  shiftId          String?
  shift            Shift?        @relation(fields: [shiftId], references: [id])
  
  items            OrderItem[]
  
  subtotal         Float
  discountType     String        @default("fixed") // DiscountType enum
  discountValue    Float         @default(0)
  totalAmount      Float
  paidAmount       Float         @default(0)
  dueAmount        Float         @default(0)
  changeAmount     Float         @default(0)
  
  orderType        String        // OrderType enum
  status           String        @default("completed") // OrderStatus enum
  paymentMethod    String        // PaymentMethod enum
  
  splitCash        Float         @default(0)
  splitCard        Float         @default(0)
  
  customerPhone    String?
  deliveryAddress  String?
  notes            String?

  returns          Return[]

  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  @@index([orderNumber])
  @@index([shiftId, status])
  @@index([customerId, status])
  @@index([totalAmount])
  @@index([createdAt])
  @@index([orderType, status])
  @@index([customerId])
  @@index([shiftId])
}

model OrderItem {
  id              String  @id @default(cuid())
  orderId         String
  order           Order   @relation(fields: [orderId], references: [id])
  
  productId       String
  product         Product @relation(fields: [productId], references: [id])
  
  productName     String?
  quantity        Int
  priceAtPurchase Float
}

model Purchase {
  id              String         @id @default(cuid())
  invoiceNumber   String         @unique
  supplierId      String
  supplier        Supplier       @relation(fields: [supplierId], references: [id])
  pharmacistId    String
  pharmacist      User           @relation(fields: [pharmacistId], references: [id])
  
  items           PurchaseItem[]
  
  totalAmount     Float
  paidAmount      Float
  remainingAmount Float          @default(0)
  status          String         @default("paid") // PurchaseStatus enum

  returns         Return[]

  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@index([invoiceNumber])
}

model PurchaseItem {
  id            String   @id @default(cuid())
  purchaseId    String
  purchase      Purchase @relation(fields: [purchaseId], references: [id])
  
  productId     String
  product       Product  @relation(fields: [productId], references: [id])
  
  quantity      Int
  purchasePrice Float
}

model Return {
  id           String       @id @default(cuid())
  returnNumber String?      @unique
  returnType   String       // ReturnType enum
  
  orderId      String?
  order        Order?       @relation(fields: [orderId], references: [id])
  
  purchaseId   String?
  purchase     Purchase?    @relation(fields: [purchaseId], references: [id])
  
  pharmacistId String
  pharmacist   User         @relation(fields: [pharmacistId], references: [id])
  
  items        ReturnItem[]
  
  totalRefund  Float
  refundMethod String       @default("cash") // RefundMethod enum
  notes        String?
  status       String       @default("completed") // ReturnStatus enum

  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@index([returnNumber])
  @@index([returnType])
  @@index([createdAt])
}

model ReturnItem {
  id            String       @id @default(cuid())
  returnId      String
  returnRecord  Return       @relation(fields: [returnId], references: [id])
  
  productId     String
  product       Product      @relation(fields: [productId], references: [id])
  
  productName   String?
  quantity      Int
  priceAtReturn Float
  reason        String       // ReturnReason enum
}

model Prescription {
  id                 String             @id @default(cuid())
  prescriptionNumber String?            @unique
  
  customerId         String
  customer           User               @relation("CustomerPrescriptions", fields: [customerId], references: [id])
  
  imageUrl           String
  notes              String?
  status             String             @default("pending") // PrescriptionStatus enum
  
  pharmacistId       String?
  pharmacist         User?              @relation("PharmacistPrescriptions", fields: [pharmacistId], references: [id])
  
  pharmacistNotes    String?
  quotedPrice        Float?
  
  items              PrescriptionItem[]
  
  customerResponse   String?            // CustomerResponse enum
  rejectionReason    String?

  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  @@index([customerId])
  @@index([status])
  @@index([createdAt])
}

model PrescriptionItem {
  id             String       @id @default(cuid())
  prescriptionId String
  prescription   Prescription @relation(fields: [prescriptionId], references: [id])
  
  productName    String?
  quantity       Int          @default(1)
  price          Float        @default(0)
}
