generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  extensions = [pg_trgm]
}

// =======================
// القوائم الثابتة (Enums)
// =======================

enum UserRole {
  superadmin
  admin
  pharmacist
  customer
}

enum AttendanceStatus {
  present
  late
  absent
  half_day
}

enum ExpenseCategory {
  rent
  electricity
  water
  salaries
  maintenance
  supplies
  other
}

enum OrderType {
  POS
  ONLINE
}

enum OrderStatus {
  pending
  processing
  completed
  delivered
  cancelled
}

enum PaymentMethod {
  cash
  visa
  pending
  split
  card
}

enum DiscountType {
  percentage
  fixed
}

enum PrescriptionStatus {
  pending
  reviewed
  quoted
  preparing
  ready
  completed
  rejected
}

enum CustomerResponse {
  accepted
  rejected
}

enum PurchaseStatus {
  paid
  partial
  unpaid
}

enum ReturnType {
  sales
  purchase
}

enum ReturnReason {
  damaged
  wrong_item
  customer_request
  expired
  defective
  overstock
  other
}

enum RefundMethod {
  cash
  exchange
  credit
}

enum ReturnStatus {
  completed
}

enum ShiftStatus {
  open
  closed
}

// =======================
// الجداول (Models)
// =======================

model User {
  id                   String         @id @default(cuid())
  name                 String
  email                String         @unique
  password             String
  phone                String?
  role                 UserRole       @default(customer)
  address              String?
  isActive             Boolean        @default(true)
  monthlyHourlyRate    Float          @default(0)
  permissions          Json?

  // العلاقات (Relations)
  attendances             Attendance[]
  expenses                Expense[]
  pharmacistOrders        Order[]        @relation("PharmacistOrders")
  customerOrders          Order[]        @relation("CustomerOrders")
  customerPrescriptions   Prescription[] @relation("CustomerPrescriptions")
  pharmacistPrescriptions Prescription[] @relation("PharmacistPrescriptions")
  purchases               Purchase[]
  returns                 Return[]
  shifts                  Shift[]
  notifications           Notification[]

  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt

  @@index([email], type: Hash)
}

model Attendance {
  id          String           @id @default(cuid())
  employeeId  String
  employee    User             @relation(fields: [employeeId], references: [id])
  date        DateTime
  checkIn     DateTime
  checkOut    DateTime?
  totalHours  Float            @default(0)
  status      AttendanceStatus @default(present)
  notes       String?

  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@unique([employeeId, date])
  @@index([date(sort: Desc)])
}

model Category {
  id          String    @id @default(cuid())
  name        String    @unique
  description String?
  image       String?
  isActive    Boolean   @default(true)
  
  products    Product[]

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Product {
  id                   String           @id @default(cuid())
  name                 String
  scientificName       String?
  barcode              String           @unique
  description          String?
  image                String?
  
  categoryId           String?
  category             Category?        @relation(fields: [categoryId], references: [id])
  
  purchasingPrice      Float
  sellingPrice         Float
  stockQuantity        Int              @default(0)
  minStockAlert        Int              @default(10)
  expiryDate           DateTime
  requiresPrescription Boolean          @default(false)
  isAvailableOnline    Boolean          @default(false)
  unit                 String           @default("قطعة")
  
  supplierId           String?
  supplier             Supplier?        @relation(fields: [supplierId], references: [id])

  orderItems           OrderItem[]
  purchaseItems        PurchaseItem[]
  returnItems          ReturnItem[]
  notifications        Notification[]

  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt

  @@index([barcode], type: Hash)
  @@index([name(ops: raw("gin_trgm_ops")), scientificName(ops: raw("gin_trgm_ops")), description(ops: raw("gin_trgm_ops"))], type: Gin)
  @@index([sellingPrice])
  @@index([categoryId])
  @@index([expiryDate])
}

model Supplier {
  id        String     @id @default(cuid())
  name      String
  company   String
  phone     String
  dues      Float      @default(0)
  
  products  Product[]
  purchases Purchase[]

  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model Expense {
  id           String          @id @default(cuid())
  description  String
  amount       Float
  category     ExpenseCategory @default(other)
  date         DateTime        @default(now())
  
  pharmacistId String
  pharmacist   User            @relation(fields: [pharmacistId], references: [id])

  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  @@index([date(sort: Desc)])
  @@index([pharmacistId, date])
}

model Shift {
  id           String      @id @default(cuid())
  pharmacistId String
  pharmacist   User        @relation(fields: [pharmacistId], references: [id])
  startTime    DateTime    @default(now())
  endTime      DateTime?
  startingCash Float       @default(0)
  endingCash   Float?
  expectedCash Float       @default(0)
  totalSales   Float       @default(0)
  totalOrders  Int         @default(0)
  totalReturns Float       @default(0)
  status       ShiftStatus @default(open)
  notes        String?
  
  orders       Order[]

  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  @@index([pharmacistId, status])
  @@index([startTime])
}

model Order {
  id               String        @id @default(cuid())
  orderNumber      String?       @unique
  
  pharmacistId     String?
  pharmacist       User?         @relation("PharmacistOrders", fields: [pharmacistId], references: [id])
  
  customerId       String?
  customer         User?         @relation("CustomerOrders", fields: [customerId], references: [id])
  
  shiftId          String?
  shift            Shift?        @relation(fields: [shiftId], references: [id])
  
  items            OrderItem[]
  
  subtotal         Float
  discountType     DiscountType  @default(fixed)
  discountValue    Float         @default(0)
  totalAmount      Float
  paidAmount       Float         @default(0)
  dueAmount        Float         @default(0)
  changeAmount     Float         @default(0)
  
  orderType        OrderType
  status           OrderStatus   @default(completed)
  paymentMethod    PaymentMethod
  
  splitCash        Float         @default(0)
  splitCard        Float         @default(0)
  
  customerPhone    String?
  deliveryAddress  String?
  notes            String?

  returns          Return[]

  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  @@index([orderNumber], type: Hash)
  @@index([shiftId, status])
  @@index([customerId, status])
  @@index([totalAmount])
  @@index([createdAt(sort: Desc)])
  @@index([orderType, status])
  @@index([customerId])
  @@index([shiftId])
}

model OrderItem {
  id              String  @id @default(cuid())
  orderId         String
  order           Order   @relation(fields: [orderId], references: [id])
  
  productId       String
  product         Product @relation(fields: [productId], references: [id])
  
  productName     String?
  quantity        Int
  priceAtPurchase Float
}

model Purchase {
  id                   String         @id @default(cuid())
  systemInvoiceNumber  Int            @unique @default(autoincrement())
  invoiceNumber        String         @unique
  companyInvoiceNumber String?
  supplierId           String
  supplier             Supplier       @relation(fields: [supplierId], references: [id])
  pharmacistId         String
  pharmacist           User           @relation(fields: [pharmacistId], references: [id])
  
  items           PurchaseItem[]
  
  totalAmount     Float
  paidAmount      Float
  remainingAmount Float          @default(0)
  status          PurchaseStatus @default(paid)

  returns         Return[]

  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@index([invoiceNumber], type: Hash)
}

model PurchaseItem {
  id            String   @id @default(cuid())
  purchaseId    String
  purchase      Purchase @relation(fields: [purchaseId], references: [id])
  
  productId     String
  product       Product  @relation(fields: [productId], references: [id])
  
  quantity      Int
  purchasePrice Float
}

model Return {
  id           String       @id @default(cuid())
  returnNumber String?      @unique
  returnType   ReturnType
  
  orderId      String?
  order        Order?       @relation(fields: [orderId], references: [id])
  
  purchaseId   String?
  purchase     Purchase?    @relation(fields: [purchaseId], references: [id])
  
  pharmacistId String
  pharmacist   User         @relation(fields: [pharmacistId], references: [id])
  
  items        ReturnItem[]
  
  totalRefund  Float
  refundMethod RefundMethod @default(cash)
  notes        String?
  status       ReturnStatus @default(completed)

  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@index([returnNumber], type: Hash)
  @@index([returnType])
  @@index([createdAt(sort: Desc)])
}

model ReturnItem {
  id            String       @id @default(cuid())
  returnId      String
  returnRecord  Return       @relation(fields: [returnId], references: [id])
  
  productId     String
  product       Product      @relation(fields: [productId], references: [id])
  
  productName   String?
  quantity      Int
  priceAtReturn Float
  reason        ReturnReason
}

model Prescription {
  id                 String             @id @default(cuid())
  prescriptionNumber String?            @unique
  
  customerId         String
  customer           User               @relation("CustomerPrescriptions", fields: [customerId], references: [id])
  
  imageUrl           String
  notes              String?
  status             PrescriptionStatus @default(pending)
  
  pharmacistId       String?
  pharmacist         User?              @relation("PharmacistPrescriptions", fields: [pharmacistId], references: [id])
  
  pharmacistNotes    String?
  quotedPrice        Float?
  
  items              PrescriptionItem[]
  
  customerResponse   CustomerResponse?
  rejectionReason    String?

  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  @@index([customerId])
  @@index([status])
  @@index([createdAt(sort: Desc)])
}

model PrescriptionItem {
  id             String       @id @default(cuid())
  prescriptionId String
  prescription   Prescription @relation(fields: [prescriptionId], references: [id])
  
  productName    String?
  quantity       Int          @default(1)
  price          Float        @default(0)
}

model Notification {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id])
  type      String    @default("reminder")
  title     String
  message   String
  productId String?
  product   Product?  @relation(fields: [productId], references: [id])
  dueDate   DateTime?
  isRead    Boolean   @default(false)
  
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([userId, isRead])
}